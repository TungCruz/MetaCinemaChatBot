GEMINI_API_KEY=your_gemini_api_key_here
DB_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=your_server;DATABASE=your_db;UID=your_uid;PWD=your_pwd;TrustServerCertificate=yes
CHATBOT_INTERNAL_SECRET=your_secret_here
INTERNAL_SECRET=your_secret_here
# URL gốc của web C# (để chatbot gọi API lấy dữ liệu attendance.json)
WEB_BASE_URL=https://your-web-domain.somee.com
